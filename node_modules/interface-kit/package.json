{
  "name": "interface-kit",
  "version": "0.1.3",
  "description": "Visual design tool for styling React apps in the browser",
  "author": "Josh Puckett",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshpuckett/interfacekit.git"
  },
  "homepage": "https://github.com/joshpuckett/interfacekit",
  "bugs": {
    "url": "https://github.com/joshpuckett/interfacekit/issues"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "sideEffects": false,
  "keywords": [
    "design",
    "editor",
    "interface",
    "react",
    "nextjs"
  ],
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "interface-kit": "^0.1.0",
    "motion": "^12.29.2"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  }
}
